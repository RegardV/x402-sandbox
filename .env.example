# x402-sandbox environment — copy to .env and fill in. NEVER commit .env.
# Receiving wallet (self-custody). On testnet any address you control works.
PAY_TO=0x0000000000000000000000000000000000000000
# CAIP-2 network. Testnet default: Base Sepolia. Mainnet: eip155:8453 (requires CDP keys).
NETWORK=eip155:84532
# Facilitator endpoint. x402.org is free and auth-less on testnet.
FACILITATOR_URL=https://x402.org/facilitator
# Admin stats page password (HTTP Basic auth, user "admin"). Min 12 chars.
ADMIN_PASSWORD=change-me-please
# Salt for hashing client IPs in the request log (any random string).
IP_SALT=change-me-too
# Optional overrides
#PORT=8402
#DB_PATH=./sandbox.db
# Mainnet only (Coinbase CDP facilitator):
#CDP_API_KEY_ID=
#CDP_API_KEY_SECRET=
