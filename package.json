{
  "name": "x402-sandbox",
  "version": "0.1.0",
  "description": "Self-hostable x402 payment gateway: make any file, folder, or endpoint sellable. Config-driven products, per-request traffic log, admin stats, public sales feed.",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "tsx src/server.ts",
    "setup": "tsx src/cli/setup.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@x402/core": "2.18.0",
    "@x402/evm": "2.18.0",
    "@x402/hono": "2.18.0",
    "@x402/paywall": "2.18.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@x402/fetch": "2.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
